{
  "name": "alone",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:3d": "pnpm --filter alone-3d dev",
    "dev:blog": "pnpm --filter alone-blog dev",
    "dev:frontplay": "pnpm --filter frontplay dev",
    "lint": "turbo run lint",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "dependencies": {
    "@vitest/eslint-plugin": "^1.6.12",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-oxlint": "^1.56.0",
    "eslint-plugin-vue": "^10.8.0",
    "jiti": "^2.6.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.7.2",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@7.1.14"
    }
  }
}
